# 环境变量示例
# 使用方式：
# 1. 复制当前文件为 .env 或直接按运行环境注入变量
# 2. 将下面的示例值替换为你自己的真实配置
# 3. 布尔值建议使用 true / false，部分运行环境也兼容 1 / 0

# ------------------------------------------------------------------------------
# 必填配置
# ------------------------------------------------------------------------------

# 95598 登录账号
# 一般为手机号或平台登录账号
SGCC_USERNAME=XXXX

# 95598 登录密码
# 请填写与上方账号对应的真实密码
SGCC_PASSWORD=XXXX

# ------------------------------------------------------------------------------
# 可选配置
# ------------------------------------------------------------------------------

# 是否开启调试日志
# true: 输出更详细的调试信息，便于排查请求和流程问题
# false: 关闭调试日志，仅保留必要输出
SGCC_DEBUG=false

# 是否展示最近五天的逐日用电明细
# true: 在通知中逐行输出最近 5 天的每日用电
# false: 仅输出“五日用电”汇总值
SGCC_SHOW_RECENT_USAGE=false

# 是否通知全部户号
# true: 账号下的所有户号都会发送通知
# false: 仅通知主流程选中的户号或默认户号
SGCC_NOTIFY_ALL_ACCOUNTS=false

# 是否以服务模式运行
# true: 按服务接口模式输出，适合被外部调用或集成
# false: 按普通脚本模式运行，适合本地测试和通知推送
SGCC_SERVICE=false

# 是否开启静默模式
# true: 尽量减少非必要输出，适合定时任务或后台运行
# false: 正常输出执行信息和结果
SGCC_SILENT=false

# ------------------------------------------------------------------------------
# Node.js / 青龙面板可选通知配置
# 说明：
# 1. 下面这些配置仅在 Node.js / 面板任务环境下生效
# 2. Surge / Loon / QuanX 等 iOS 代理工具仍然走原生系统通知，不受影响
# 3. 如果同时配置 Bark 和 Telegram，会两个渠道都发送
# ------------------------------------------------------------------------------

# Bark 推送地址
# 支持两种写法：
# 1. 完整地址，例如 https://api.day.app/xxxxxxxx
# 2. 仅填写设备 key，脚本会自动补全为官方地址
BARK_PUSH=

# Bark 通知铃声，可选
# 具体铃声名称请以 Bark App 内实际支持项为准
BARK_SOUND=

# Bark 通知分组，可选
# 用于在 Bark App 内将同类消息归类显示
BARK_GROUP=

# Bark 图标地址，可选
# 可填写一个可公开访问的图片链接
BARK_ICON=

# Telegram Bot Token
# 例如 123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TG_BOT_TOKEN=

# Telegram 接收用户 ID 或群组 ID
# 发送前请确保 bot 已与目标用户或群组建立过会话
TG_USER_ID=

# Telegram API 域名，可选
# 默认使用 api.telegram.org
# 如果你有自建反代，可以填写自己的域名
TG_API_HOST=api.telegram.org

# Telegram HTTP 代理主机地址，可选
# 中国大陆用户如无法直连 Telegram，可配置本地代理地址
# 例如 127.0.0.1
TG_PROXY_HOST=

# Telegram HTTP 代理端口，可选
# 例如 7890
TG_PROXY_PORT=

# Telegram 代理认证信息，可选
# 如果代理需要用户名密码认证，可填写 user:password
TG_PROXY_AUTH=

# ------------------------------------------------------------------------------
# 其他 Node.js / 青龙面板可选通知配置
# 说明：
# 1. 以下配置同样只在 Node.js / 面板任务环境下生效
# 2. iOS 代理工具仍然保持原有系统通知行为，不受这些配置影响
# 3. 若同时配置多个渠道，脚本会并行发送
# ------------------------------------------------------------------------------

# server 酱 Push Key
# 老版 server 酱和 Turbo 版均可，脚本会自动识别对应接口
PUSH_KEY=

# 钉钉机器人 access_token
DD_BOT_TOKEN=

# 钉钉机器人加签密钥，可选
# 若机器人开启了安全加签，则需要填写
DD_BOT_SECRET=

# 企业微信机器人 webhook key
QYWX_KEY=

# 企业微信应用消息配置
# 格式：
# corpid,corpsecret,touser,agentid,msgType
# 其中 msgType 可选：
# 0 表示 textcard
# 1 表示 text
# 其他值会按 mpnews 的 thumb_media_id 处理
QYWX_AM=

# iGot 推送 key
IGOT_PUSH_KEY=

# PushPlus Token
PUSH_PLUS_TOKEN=

# PushPlus 群组编码，可选
# 不填时默认为一对一推送
PUSH_PLUS_USER=

# WxPusher appToken
WP_APP_TOKEN=

# WxPusher topicIds，可选
# 多个 topicId 使用英文分号 ; 分隔
WP_TOPICIDS=

# WxPusher uids，可选
# 多个 uid 使用英文分号 ; 分隔
WP_UIDS=

# WxPusher 点击跳转链接，可选
WP_URL=

# gotify 服务地址
# 例如 https://push.example.com
GOTIFY_URL=

# gotify 应用 token
GOTIFY_TOKEN=

# gotify 消息优先级，可选
# 默认 0
GOTIFY_PRIORITY=0

# go-cqhttp 请求地址
# 例如 http://127.0.0.1:5700/send_private_msg
# 或 http://127.0.0.1:5700/send_group_msg
GOBOT_URL=

# go-cqhttp access_token，可选
GOBOT_TOKEN=

# go-cqhttp 目标参数
# 例如 user_id=123456 或 group_id=123456
GOBOT_QQ=

# Bncr 面板地址
# 例如 http://127.0.0.1:9090
BncrHost=

# Bncr 消息 token
BncrToken=
