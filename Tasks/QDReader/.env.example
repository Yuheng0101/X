# ============================================================
# 起点读书签到 — Node.js / 青龙面板环境变量配置
# 复制本文件为 .env，按需填写后即可使用
# ============================================================

# ---------------------- 脚本配置 ----------------------

# 账号 Cookie，JSON Map 格式：{"uid":"完整cookie字符串"}
# 多账号示例：{"123456":"cmfuToken=xxx;QDH=xxx;...","789012":"cmfuToken=yyy;..."}
# 也可直接填写单个 Cookie 字符串（单账号模式）
QDREADER_COOKIE=

# 是否开启调试模式（true / false）
# 开启后会输出请求头、请求体和响应信息
QDREADER_DEBUG=false

# ------------------------------------------------------------------------------
# Node.js / 青龙面板可选通知配置
# 说明：
# 1. 下面这些配置仅在 Node.js / 面板任务环境下生效
# 2. Surge / Loon / QuanX 等 iOS 代理工具仍然走原生系统通知，不受影响
# 3. 如果同时配置 Bark 和 Telegram，会两个渠道都发送
# ------------------------------------------------------------------------------

# Bark 推送地址
# 支持两种写法：
# 1. 完整地址，例如 https://api.day.app/xxxxxxxx
# 2. 仅填写设备 key，脚本会自动补全为官方地址
BARK_PUSH=

# Bark 通知铃声，可选
# 具体铃声名称请以 Bark App 内实际支持项为准
BARK_SOUND=

# Bark 通知分组，可选
# 用于在 Bark App 内将同类消息归类显示
BARK_GROUP=

# Bark 图标地址，可选
# 可填写一个可公开访问的图片链接
BARK_ICON=

# Telegram Bot Token
# 例如 123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TG_BOT_TOKEN=

# Telegram 接收用户 ID 或群组 ID
# 发送前请确保 bot 已与目标用户或群组建立过会话
TG_USER_ID=

# Telegram API 域名，可选
# 默认使用 api.telegram.org
# 如果你有自建反代，可以填写自己的域名
TG_API_HOST=api.telegram.org

# Telegram HTTP 代理主机地址，可选
# 中国大陆用户如无法直连 Telegram，可配置本地代理地址
# 例如 127.0.0.1
TG_PROXY_HOST=

# Telegram HTTP 代理端口，可选
# 例如 7890
TG_PROXY_PORT=

# Telegram 代理认证信息，可选
# 如果代理需要用户名密码认证，可填写 user:password
TG_PROXY_AUTH=

# ------------------------------------------------------------------------------
# 其他 Node.js / 青龙面板可选通知配置
# 说明：
# 1. 以下配置同样只在 Node.js / 面板任务环境下生效
# 2. iOS 代理工具仍然保持原有系统通知行为，不受这些配置影响
# 3. 若同时配置多个渠道，脚本会并行发送
# ------------------------------------------------------------------------------

# server 酱 Push Key
# 老版 server 酱和 Turbo 版均可，脚本会自动识别对应接口
PUSH_KEY=

# 钉钉机器人 access_token
DD_BOT_TOKEN=

# 钉钉机器人加签密钥，可选
# 若机器人开启了安全加签，则需要填写
DD_BOT_SECRET=

# 企业微信机器人 webhook key
QYWX_KEY=

# 企业微信应用消息配置
# 格式：
# corpid,corpsecret,touser,agentid,msgType
# 其中 msgType 可选：
# 0 表示 textcard
# 1 表示 text
# 其他值会按 mpnews 的 thumb_media_id 处理
QYWX_AM=

# iGot 推送 key
IGOT_PUSH_KEY=

# PushPlus Token
PUSH_PLUS_TOKEN=

# PushPlus 群组编码，可选
# 不填时默认为一对一推送
PUSH_PLUS_USER=

# WxPusher appToken
WP_APP_TOKEN=

# WxPusher topicIds，可选
# 多个 topicId 使用英文分号 ; 分隔
WP_TOPICIDS=

# WxPusher uids，可选
# 多个 uid 使用英文分号 ; 分隔
WP_UIDS=

# WxPusher 点击跳转链接，可选
WP_URL=

# gotify 服务地址
# 例如 https://push.example.com
GOTIFY_URL=

# gotify 应用 token
GOTIFY_TOKEN=

# gotify 消息优先级，可选
# 默认 0
GOTIFY_PRIORITY=0

# go-cqhttp 请求地址
# 例如 http://127.0.0.1:5700/send_private_msg
# 或 http://127.0.0.1:5700/send_group_msg
GOBOT_URL=

# go-cqhttp access_token，可选
GOBOT_TOKEN=

# go-cqhttp 目标参数
# 例如 user_id=123456 或 group_id=123456
GOBOT_QQ=

# Bncr 面板地址
# 例如 http://127.0.0.1:9090
BncrHost=

# Bncr 消息 token
BncrToken=
