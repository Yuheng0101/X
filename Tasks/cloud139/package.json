  "scripts": {
    "clean": "node -e \"const fs=require('fs');['dist/request.js','dist/request.dev.js','dist/response.js','dist/response.dev.js','dist/capture.js','dist/capture.dev.js','dist/cloud139.js','dist/cloud139.dev.js'].forEach(file=>{if(fs.existsSync(file))fs.unlinkSync(file);});\"",
