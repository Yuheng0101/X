[Script]
GitHub源文件自动CDN = type=http-request, pattern=^https?://raw\.githubusercontent\.com/.+, script-path=https://raw.githubusercontent.com/Yuheng0101/X/main/Scripts/GitRawAutoCDN/index.js, timeout=5

[MITM]
hostname = %APPEND% raw.githubusercontent.com
